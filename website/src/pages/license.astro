---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/ui/Container.astro";
import Card from "../components/ui/Card.astro";
import { CONTACT_EMAIL } from "../utils/constants";
---

<MainLayout
  title="License"
  description="License information for code and data provided by Open Waters."
>
  <Container class="py-16">
    <div class="mx-auto max-w-4xl">
      <h1 class="mb-8">License Information</h1>

      <div class="prose prose-lg mb-12 max-w-none">
        <p class="text-navy-600 text-xl">
          Open Waters is committed to open source software and open data. Below
          you'll find information about how our code and data are licensed.
        </p>
      </div>

      <div class="space-y-8">
        <!-- Software License -->
        <Card>
          <div class="flex items-start gap-4">
            <div class="text-ocean-600 mt-1">
              <svg
                class="h-8 w-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="mb-3 text-2xl font-semibold">Software License</h2>
              <p class="text-navy-600 mb-4">
                All software projects developed by Open Waters are released
                under the
                <strong>MIT License</strong> unless otherwise specified.
              </p>
              <div class="bg-navy-50 mb-4 rounded-lg p-4 font-mono text-sm">
                <p class="mb-2">MIT License</p>
                <p class="text-navy-600 text-xs leading-relaxed">
                  Permission is hereby granted, free of charge, to any person
                  obtaining a copy of this software and associated documentation
                  files (the "Software"), to deal in the Software without
                  restriction, including without limitation the rights to use,
                  copy, modify, merge, publish, distribute, sublicense, and/or
                  sell copies of the Software.
                </p>
              </div>
              <p class="text-navy-600 text-sm">
                This means you are free to use, modify, and distribute our code
                for any purpose, including commercial applications.
              </p>
            </div>
          </div>
        </Card>

        <!-- Data License -->
        <Card>
          <div class="flex items-start gap-4">
            <div class="text-ocean-600 mt-1">
              <svg
                class="h-8 w-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
                ></path>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="mb-3 text-2xl font-semibold">Data License</h2>
              <p class="text-navy-600 mb-4">
                Data provided by Open Waters is generally licensed under the
                <strong
                  >Creative Commons CC0 1.0 Universal (CC0 1.0) Public Domain
                  Dedication</strong
                >
                or <strong>Open Database License (ODbL)</strong>, depending on
                the dataset.
              </p>
              <div class="mb-4 space-y-3">
                <div class="border-ocean-400 border-l-4 pl-4">
                  <h3 class="mb-1 font-semibold">CC0 1.0 - Public Domain</h3>
                  <p class="text-navy-600 text-sm">
                    Our original datasets are released to the public domain,
                    allowing unrestricted use without attribution requirements.
                  </p>
                </div>
                <div class="border-ocean-400 border-l-4 pl-4">
                  <h3 class="mb-1 font-semibold">ODbL - Share-Alike</h3>
                  <p class="text-navy-600 text-sm">
                    Some datasets, particularly those derived from or
                    incorporating other ODbL data, require that derivative works
                    be shared under the same license.
                  </p>
                </div>
              </div>
              <p class="text-navy-600 text-sm">
                Each dataset includes specific license information in its
                documentation and metadata.
              </p>
            </div>
          </div>
        </Card>

        <!-- Third-Party Data -->
        <Card>
          <div class="flex items-start gap-4">
            <div class="text-ocean-600 mt-1">
              <svg
                class="h-8 w-8"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div class="flex-1">
              <h2 class="mb-3 text-2xl font-semibold">Third-Party Data</h2>
              <p class="text-navy-600 mb-4">
                We incorporate data from various sources, each with their own
                licensing terms:
              </p>
              <ul class="text-navy-600 space-y-2">
                <li class="flex items-start gap-2">
                  <span class="text-ocean-600 mt-1">•</span>
                  <span
                    ><strong>NOAA Tide Data:</strong> Public domain data from the
                    National Oceanic and Atmospheric Administration</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ocean-600 mt-1">•</span>
                  <span
                    ><strong>IHO TICON Database:</strong> International Hydrographic
                    Organization tide constituent data</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ocean-600 mt-1">•</span>
                  <span
                    ><strong>Community Contributions:</strong> Crowd-sourced data
                    subject to contributor agreements</span
                  >
                </li>
              </ul>
              <p class="text-navy-600 mt-4 text-sm">
                When using our data, please review the specific license and
                attribution requirements for each source.
              </p>
            </div>
          </div>
        </Card>

        <!-- Attribution -->
        <Card class="border-ocean-200 bg-ocean-50">
          <h2 class="mb-3 text-2xl font-semibold">Attribution Guidelines</h2>
          <p class="text-navy-600 mb-4">
            While not always required, we appreciate attribution when you use
            our work. Here's how you can credit Open Waters:
          </p>
          <div class="border-ocean-200 rounded-lg border bg-white p-4">
            <p class="text-navy-800 font-mono text-sm">
              Data/Software from <a
                href="https://openwaters.io"
                class="text-ocean-600 hover:text-ocean-700">Open Waters</a
              >
              (<a
                href="https://github.com/openwatersio"
                class="text-ocean-600 hover:text-ocean-700"
                >github.com/openwatersio</a
              >)
            </p>
          </div>
        </Card>

        <!-- Questions -->
        <Card class="border-navy-200 bg-navy-50">
          <div class="text-center">
            <h2 class="mb-3 text-2xl font-semibold">
              Questions About Licensing?
            </h2>
            <p class="text-navy-600 mb-6">
              If you have questions about how you can use our code or data, or
              need clarification on licensing terms, please don't hesitate to
              reach out.
            </p>
            <a href={`mailto:${CONTACT_EMAIL}`} class="btn btn-primary">
              Contact Us
            </a>
          </div>
        </Card>
      </div>

      <!-- Additional Info -->
      <div class="border-navy-200 bg-navy-50 mt-12 rounded-lg border p-6">
        <h3 class="text-navy-900 mb-2 font-semibold">Important Note</h3>
        <p class="text-navy-600 text-sm">
          This page provides a general overview of our licensing approach. For
          specific projects, always refer to the LICENSE file included in each
          repository or dataset. When in doubt, check the project's README or
          contact us directly.
        </p>
      </div>
    </div>
  </Container>
</MainLayout>
