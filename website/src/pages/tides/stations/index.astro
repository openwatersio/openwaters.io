---
import MainLayout from "../../../layouts/MainLayout.astro";
import { StationsMapIsland } from "../../../components/tides/StationsMapIsland";
import Feature from "../../../components/ui/Feature.astro";
---

<MainLayout
  title="Tide Stations"
  description="Browse and search thousands of tide stations worldwide on an interactive map."
  fullscreen
>
  <StationsMapIsland client:only="react">
    <div class="card-glass overflow-hidden rounded-3xl p-0">
      <h6 class="px-4 pt-3 pb-1 text-base text-slate-500">Developer Tools</h6>
      <ul class="divide-navy-200 divide-y">
        <li>
          <a class="hover:bg-ocean-200/50 block px-4 py-3" href="/api">
            <Feature
              title="API"
              description="Station data and predictions via a REST API."
              icon="mdi:code-greater-than"
            />
          </a>
        </li>

        <li>
          <a class="hover:bg-ocean-200/50 block px-4 py-3" href="/tides/neaps">
            <Feature
              title="Neaps"
              description="An open source tide prediction engine."
              icon="mdi:code"
            />
          </a>
        </li>

        <li>
          <a
            class="hover:bg-ocean-200/50 block px-4 py-3"
            href="/tides/database"
          >
            <Feature
              title="Tide Database"
              description="Harmonic constituents for thousands of stations globally."
              icon="mdi:database-outline"
            />
          </a>
        </li>
      </ul>
    </div>
  </StationsMapIsland>
</MainLayout>
