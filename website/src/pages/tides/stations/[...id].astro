---
import MainLayout from "../../../layouts/MainLayout.astro";
import Container from "../../../components/ui/Container.astro";
import Card from "../../../components/ui/Card.astro";
import type { Station } from "@neaps/tide-database";
import { TideStationIsland } from "../../../components/tides/TideStationIsland";
import { NearbyStationsIsland } from "../../../components/tides/NearbyStations";
import { Icon } from "astro-icon/components";
import { API_HOST } from "../../../utils/constants";
import {
  createQueryClient,
  prefetchTideStation,
  prefetchNearbyStations,
  dehydrate,
} from "@neaps/react";

// Enable server-side rendering for this route
export const prerender = false;

const response = await fetch(`${API_HOST}/tides/stations/${Astro.params.id}`);
if (!response.ok) {
  return new Response(null, { status: 404 });
}
const station: Station = await response.json();

let referenceStation: Station | null = null;
if (station.offsets?.reference) {
  const refResponse = await fetch(
    `${API_HOST}/tides/stations/${station.offsets.reference}`,
  );
  if (refResponse.ok) {
    referenceStation = await refResponse.json();
  }
}

// Determine locale from Accept-Language header
const acceptLang = Astro.request.headers.get("accept-language") ?? "";
const locale = acceptLang.split(",")[0]?.split(";")[0]?.trim() || "en-US";

// Prefetch tide data so React islands render with data immediately
const queryClient = createQueryClient();
await Promise.all([
  prefetchTideStation(queryClient, API_HOST, station.id, { locale }),
  prefetchNearbyStations(queryClient, API_HOST, {
    latitude: station.latitude,
    longitude: station.longitude,
  }),
]);
const dehydratedState = dehydrate(queryClient);
---

<MainLayout title={station.name} description={`Tide station: ${station.name}`}>
  <Container>
    <div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-3">
      {/* Main content */}
      <div class="min-w-0 space-y-4 lg:col-span-2">
        <div>
          <a
            href="/tides/stations"
            class="text-ocean-600 hover:text-ocean-700 inline-block"
          >
            ← Back to stations
          </a>
        </div>

        {
          station.disclaimers &&
            station.disclaimers !== "No obvious issues" && (
              <div
                class="mb-4 flex items-center gap-3 rounded border p-4 text-sm"
                style="background-color: var(--status-red-bg); color: var(--status-red-text); border-color: var(--status-red-border);"
              >
                <Icon
                  name="mdi:alert-circle-outline"
                  class="mt-0.5 h-5 w-5 shrink-0"
                />
                {station.disclaimers}
              </div>
            )
        }

        <TideStationIsland
          client:load
          id={station.id}
          dehydratedState={dehydratedState}
        />

        <Card class="mt-8">
          <section>
            <div
              class="mb-6 flex items-center justify-between gap-8 border-b border-(--border) pb-4"
            >
              <div>
                <h3 class="text-xl">Station Data</h3>
                <p class="text-sm">
                  Data for this station comes from the
                  <a href="/tides/database">Tide Database</a>.
                </p>
              </div>
              <a
                href={`https://github.com/openwatersio/tide-database/blob/main/data/${station.id}.json`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn inline-flex items-center gap-2"
              >
                Station Data
                <Icon name="mdi:chevron-right" class="h-4 w-4" />
              </a>
            </div>

            <dl>
              <dt>Source</dt>
              <dd>
                <a
                  href={station.source.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {station.source.name}
                </a>
              </dd>

              <dt>Source ID</dt>
              <dd class="font-mono">{station.source.id}</dd>

              <dt>License</dt>
              <dd>
                <a
                  href={station.license.url}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {station.license.type}
                </a>
                {
                  !station.license.commercial_use && (
                    <span class="ml-2 rounded bg-(--status-yellow-bg) px-2 py-0.5 text-xs text-(--status-yellow-text)">
                      Non-commercial
                    </span>
                  )
                }
              </dd>

              {
                station.license.notes && (
                  <>
                    <dt>License Notes</dt>
                    <dd class="text-(--text-secondary)">
                      {station.license.notes}
                    </dd>
                  </>
                )
              }

              <dt>Type</dt>
              <dd class="capitalize">{station.type}</dd>

              {
                referenceStation && station.offsets && (
                  <>
                    <dt>Reference Station</dt>
                    <dd>
                      <a href={`/tides/stations/${referenceStation.id}`}>
                        {referenceStation.name}
                      </a>
                    </dd>

                    <dt>Height Offsets</dt>
                    <dd>
                      High: {station.offsets.height.high}
                      {station.offsets.height.type === "ratio" ? "x" : "m"},
                      Low: {station.offsets.height.low}
                      {station.offsets.height.type === "ratio" ? "x" : "m"}
                      <span class="ml-1 text-(--text-muted)">
                        ({station.offsets.height.type})
                      </span>
                    </dd>

                    <dt>Time Offsets</dt>
                    <dd>
                      High: {station.offsets.time.high > 0 ? "+" : ""}
                      {station.offsets.time.high} min, Low:{" "}
                      {station.offsets.time.low > 0 ? "+" : ""}
                      {station.offsets.time.low} min
                    </dd>
                  </>
                )
              }

              <dt>Timezone</dt>
              <dd>{station.timezone}</dd>

              <dt>Chart Datum</dt>
              <dd>{station.chart_datum}</dd>

              {
                station.epoch && (
                  <>
                    <dt>Epoch</dt>
                    <dd>
                      {station.epoch.start} – {station.epoch.end}
                    </dd>
                  </>
                )
              }
            </dl>
          </section>
        </Card>

        <Card>
          <section>
            <div
              class="mb-6 flex items-center justify-between gap-8 border-b border-(--border-subtle) pb-4"
            >
              <div>
                <h3 class="text-xl">API</h3>
                <p class="text-sm">
                  Access tide predictions for this station via the
                  <a href="/api">API</a>.
                </p>
              </div>
              <a href="/api" class="btn inline-flex items-center gap-2">
                API Docs
                <Icon name="mdi:chevron-right" class="h-4 w-4" />
              </a>
            </div>

            <div class="space-y-4">
              <div>
                <h4 class="mb-2 text-sm font-semibold text-(--text-secondary)">
                  Get station info
                </h4>
                <div class="flex items-center gap-3 overflow-x-auto">
                  <span
                    class="shrink-0 rounded-sm bg-(--status-green-bg) px-2 py-1 text-xs font-bold text-(--status-green-text)"
                    >GET</span
                  >
                  <span class="font-mono text-sm"
                    >{API_HOST}/tides/stations/{station.id}</span
                  >
                </div>
              </div>

              <div>
                <h4 class="mb-2 text-sm font-semibold text-(--text-secondary)">
                  Get tide extremes (high/low)
                </h4>
                <div class="flex items-center gap-3 overflow-x-auto">
                  <span
                    class="rounded-sm bg-(--status-green-bg) px-2 py-1 text-xs font-bold text-(--status-green-text)"
                    >GET</span
                  >
                  <span class="font-mono text-sm"
                    >{API_HOST}/tides/stations/{station.id}/extremes</span
                  >
                </div>
              </div>
            </div>
          </section>
        </Card>
        <Card>
          <section>
            <div
              class="mb-6 flex items-center justify-between gap-8 border-b border-(--border-subtle) pb-4"
            >
              <div>
                <h3 class="text-xl">JavaScript</h3>
                <p class="text-sm">
                  Use the <a href="/tides/neaps">neaps</a>
                  npm library to compute tide predictions locally.
                </p>
              </div>
              <a href="/tides/neaps" class="btn inline-flex items-center gap-2">
                Neaps Docs
                <Icon name="mdi:chevron-right" class="h-4 w-4" />
              </a>
            </div>

            <div class="space-y-4">
              <div>
                <h4 class="mb-2 text-sm font-semibold text-(--text-secondary)">
                  Install
                </h4>
                <pre
                  class="bg-navy-900 overflow-x-auto rounded-lg p-4 text-sm text-white"><code>npm install neaps</code></pre>
              </div>

              <div>
                <h4 class="mb-2 text-sm font-semibold text-(--text-secondary)">
                  Get tide predictions
                </h4>
                <pre
                  class="bg-navy-900 overflow-x-auto rounded-lg p-4 text-sm text-white"><code>{`import { findStation } from "neaps";

const station = findStation("${station.id}");

// Get highs and lows for a specific date range
const extremes = station.getExtremesPrediction({
  start: new Date("2025-01-01"),
  end: new Date("2025-01-02"),
});
console.log(extremes);`}</code></pre>
              </div>
            </div>
          </section>
        </Card>
      </div>

      {/* Sidebar */}
      <div class="min-w-0 lg:col-span-1">
        <NearbyStationsIsland
          client:load
          stationId={station.id}
          latitude={station.latitude}
          longitude={station.longitude}
          dehydratedState={dehydratedState}
        />
      </div>
    </div>
  </Container>
</MainLayout>
