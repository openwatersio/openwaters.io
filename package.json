{
  "name": "openwaters-monorepo",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "website",
    "api"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w website\" \"npm run dev -w api\"",
    "dev:website": "npm run dev -w website",
    "dev:api": "npm run dev -w api",
    "build": "npm run build -w website"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@neaps/api": "^0.4.0",
    "@neaps/react": "https://pkg.pr.new/openwatersio/neaps/@neaps/react@aeaab8f",
    "@neaps/tide-database": "^0.6.20260220",
    "@neaps/tide-predictor": "^0.8.0",
    "neaps": "^0.6.0"
  }
}
